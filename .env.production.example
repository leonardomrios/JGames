# Generar con: openssl rand -base64 32
AUTH_SECRET=cambiar-este-valor

# Password del usuario gamekids_user en el Postgres nativo del VPS.
# Debe coincidir exactamente con la password configurada en ese usuario.
POSTGRES_PASSWORD=cambiar-este-valor

# La DATABASE_URL se construye automaticamente en docker-compose.production.yml
# No necesita estar aqui - se inyecta como variable de entorno del contenedor
